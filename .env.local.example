# AWS Cognito
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# AWS S3
AWS_S3_BUCKET_NAME=math-tutoring-files
AWS_REGION=us-east-1

# AWS Credentials (for API routes - use IAM role in production)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# DynamoDB
DYNAMODB_TABLE_SESSIONS=math-tutoring-sessions
DYNAMODB_TABLE_USERS=math-tutoring-users
DYNAMODB_TABLE_AVAILABILITY=math-tutoring-availability

# SES
SES_FROM_EMAIL=tutor@yourdomain.com

# Tutor Config
TUTOR_EMAIL=your-email@example.com
